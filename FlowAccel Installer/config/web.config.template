<?xml version="1.0" encoding="UTF-8"?>
<!--
  FlowAccel IIS site configuration (HTTP-only reverse proxy).
  Prerequisites: URL Rewrite Module 2.1 + Application Request Routing (ARR) 3.0.

  __BACKEND_PORT__ is substituted with the real backend port by the installer
  (Copy-AppFiles in site.ps1) so the proxy port can never drift from the
  backend's actual listening port.

  Serves:
    - React static files from the site root (dist\)
    - /api/*       -> reverse proxy to the Node.js backend on 127.0.0.1
    - /socket.io/* -> reverse proxy to the Node.js backend on 127.0.0.1
    - /uploads/*   -> reverse proxy to the Node.js backend on 127.0.0.1
    - Everything else -> index.html (SPA client-side routing)

  Note: no <webSocket> element. The frontend uses HTTP polling, not Socket.IO
  over WebSocket; the <webSocket> section is server-locked and including it
  causes HTTP 500.19 when the IIS WebSocket feature is absent.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Proxy /api/* to the Node.js backend -->
        <rule name="API Proxy" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:__BACKEND_PORT__/api/{R:1}" />
        </rule>

        <!-- Proxy /socket.io/* to the Node.js backend -->
        <rule name="Socket.IO Proxy" stopProcessing="true">
          <match url="^socket\.io/(.*)" />
          <action type="Rewrite" url="http://localhost:__BACKEND_PORT__/socket.io/{R:1}" />
        </rule>

        <!-- Proxy /uploads/* to the Node.js backend -->
        <rule name="Uploads Proxy" stopProcessing="true">
          <match url="^uploads/(.*)" />
          <action type="Rewrite" url="http://localhost:__BACKEND_PORT__/uploads/{R:1}" />
        </rule>

        <!-- Static files served directly by IIS -->
        <rule name="StaticContent" stopProcessing="true">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- SPA fallback: serve index.html for all non-file routes -->
        <rule name="SPA Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- Default document -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-XSS-Protection" value="1; mode=block" />
      </customHeaders>
    </httpProtocol>

    <!-- Static content MIME types -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <!-- FlowAccel installer download (split 7-Zip archive) -->
      <mimeMap fileExtension=".7z" mimeType="application/x-7z-compressed" />
      <mimeMap fileExtension=".001" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".002" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".003" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".004" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".005" mimeType="application/octet-stream" />
    </staticContent>

    <!-- Hide sensitive paths -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment="backend" />
          <add segment=".env" />
          <add segment=".git" />
        </hiddenSegments>
        <requestLimits maxAllowedContentLength="10485760" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
