# Copy this to C:/JotFlow/production.env on the Windows PC. Never commit that file.
APP_PORT=8080

# PostgreSQL container (use a long, unique password)
POSTGRES_USER=jotflow
POSTGRES_PASSWORD=replace-with-a-long-unique-password
POSTGRES_DB=jotflow
DATABASE_URL=postgresql://jotflow:replace-with-the-same-password@db:5432/jotflow

# Generate with: [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
SESSION_SECRET=replace-with-a-random-secret
NODE_ENV=production

# Replace with the IP reported by: ipconfig
ALLOWED_ORIGIN=http://192.168.1.50:8080
PUBLIC_BASE_URL=http://192.168.1.50:8080

# Required JotForm credentials
JOTFORM_API_KEY=
JOTFORM_API_KEY_GDMO=
JOTFORM_TEAM_ID=
JOTFORM_WEBHOOK_SECRET=

# Enable only one poller instance (the backend container is that instance).
ENABLE_POLLER=1
POLL_INTERVAL_MINUTES=2
POLL_QUICK_SECONDS=1
POLLER_KEY_TYPE=gdmo

# Add the optional Microsoft, SMTP, IMAP, and admin variables from backend/.env.example as needed.
