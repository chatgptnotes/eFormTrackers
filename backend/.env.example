# PostgreSQL
DATABASE_URL=postgresql://jotflow:yourpassword@localhost:5432/jotflow

# Session
SESSION_SECRET=change-me-to-a-random-64-char-string

# JotForm API
JOTFORM_API_KEY=your-jotform-api-key
JOTFORM_TEAM_ID=
JOTFORM_BASE=https://eforms.mediaoffice.ae/API
JOTFORM_HOST=https://eforms.mediaoffice.ae
JOTFORM_WEBHOOK_SECRET=

# CORS
ALLOWED_ORIGIN=http://localhost:5173

# Server
PORT=3001
NODE_ENV=development

# Background JotForm database sync
ENABLE_POLLER=1
POLL_INTERVAL_MINUTES=5
POLL_QUICK_SECONDS=20
POLLER_KEY_TYPE=gdmo

# Optional: sync a sender mailbox's Sent folder into jotform_mail_sender.
# For Gmail, enable IMAP and use a Google app password, not the normal account password.
MAIL_SENDER_ENABLED=0
MAIL_SENDER_ACCOUNT=bkmurali683@gmail.com
MAIL_SENDER_IMAP_HOST=imap.gmail.com
MAIL_SENDER_IMAP_PORT=993
MAIL_SENDER_IMAP_SECURE=1
MAIL_SENDER_IMAP_USER=bkmurali683@gmail.com
MAIL_SENDER_IMAP_PASS=
MAIL_SENDER_IMAP_MAILBOX=[Gmail]/Sent Mail
MAIL_SENDER_SYNC_LIMIT=500
MAIL_SENDER_MAX_BYTES=5242880
MAIL_SENDER_SOCKET_TIMEOUT_MS=600000
