<?xml version="1.0" encoding="UTF-8"?>
<!--
  FlowAccel — iisnode web.config (self-contained, IIS-managed Node backend)

  Model:
    IIS hosts server.js directly via the iisnode module. A single Node process
    serves the React build (dist/), the REST API (/api), uploaded files
    (/uploads) and Socket.IO (/socket.io). IIS starts, stops and recycles the
    process automatically — no PM2, no separate port.

  Prerequisites (installed by install-iis-iisnode.ps1):
    - iisnode module
    - URL Rewrite Module 2.x
    - IIS WebSockets feature (for Socket.IO upgrade)

  Folder layout at the IIS site root (C:\inetpub\flowaccel\):
    server.js          <- iisnode entry point
    web.config         <- this file
    dist\              <- React production build (served as static by IIS)
    backend\           <- Express app + node_modules + .env (hidden from web)
-->
<configuration>
  <system.webServer>

    <!-- Register server.js to be handled by iisnode -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <webSocket enabled="true" />

    <rewrite>
      <rules>
        <!--
          Route every request to the Node process. server.js serves the React
          build (dist/) as static, exposes /api + /socket.io + /uploads, and
          falls back to index.html for SPA client-side routes. Keeping a single
          entry point avoids dist-subfolder path mismatches in IIS.
        -->
        <rule name="AllToNode">
          <match url=".*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- iisnode runtime configuration -->
    <iisnode
      nodeProcessCommandLine="&quot;C:\Program Files\nodejs\node.exe&quot;"
      watchedFiles="web.config;*.js;backend\*.js;backend\.env"
      loggingEnabled="true"
      logDirectory="iisnode"
      devErrorsEnabled="false"
      node_env="development"
      maxConcurrentRequestsPerProcess="1024"
      nodeProcessCountPerApplication="1" />

    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-XSS-Protection" value="1; mode=block" />
      </customHeaders>
    </httpProtocol>

    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <mimeMap fileExtension=".7z" mimeType="application/x-7z-compressed" />
      <mimeMap fileExtension=".001" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".002" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".003" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".004" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".005" mimeType="application/octet-stream" />
    </staticContent>

    <!-- Keep server-side code and secrets unreachable from the web -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment="iisnode" />
          <add segment=".env" />
          <add segment=".git" />
        </hiddenSegments>
        <requestLimits maxAllowedContentLength="10485760" />
      </requestFiltering>
    </security>

    <httpErrors existingResponse="PassThrough" />

  </system.webServer>
</configuration>
